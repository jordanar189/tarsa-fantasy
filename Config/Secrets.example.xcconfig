// Copy this file to Secrets.xcconfig (same folder) and paste your real key.
// Secrets.xcconfig is gitignored, so the key never lands in source control.
//
// Get a free GIPHY API key at https://developers.giphy.com (create an "API"
// app, not "SDK"). The default beta key is rate-limited — request a
// production key before shipping.

GIPHY_API_KEY = your_giphy_api_key_here
