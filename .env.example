# App Store Connect API credentials for scripts/upload-testflight.sh
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# App Store Connect API key — generate at:
#   https://appstoreconnect.apple.com/access/integrations/api
# Pick role "App Manager" (or higher). Download the .p8 file ONCE — Apple does
# not let you re-download it. Save it somewhere safe (e.g. ~/.appstoreconnect/private_keys/).

# 10-character Key ID shown next to the key in the ASC integrations page.
# The .p8 file MUST be saved at ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8
# — altool only looks in that conventional location, not at an arbitrary path.
#   mkdir -p ~/.appstoreconnect/private_keys
#   mv ~/Downloads/AuthKey_XXXXXXXXXX.p8 ~/.appstoreconnect/private_keys/
ASC_KEY_ID=XXXXXXXXXX

# UUID shown at the top of the ASC integrations page (one per team).
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Your 10-character Apple Developer Team ID. Already known from project.pbxproj
# (VQHSK86XP2) but kept in .env so the script doesn't hardcode it.
ASC_TEAM_ID=VQHSK86XP2
